{
    "title": "Full Feature Preview Form",
    "description": "A comprehensive preview form demonstrating all available question types and validation rules.",
    "fields": [
        {
            "id": "field_text_1",
            "type": "text",
            "label": "Full Name",
            "required": true,
            "placeholder": "Enter your full name",
            "description": "Please provide your legal name as it appears on documents."
        },
        {
            "id": "field_textarea_1",
            "type": "textarea",
            "label": "Detailed Biography",
            "required": false,
            "placeholder": "Tell us about yourself...",
            "description": "A brief overview of your professional background and interests."
        },
        {
            "id": "field_select_1",
            "type": "select",
            "label": "Preferred Contact Method",
            "required": true,
            "options": [
                {
                    "label": "Email",
                    "value": "email"
                },
                {
                    "label": "Phone",
                    "value": "phone"
                },
                {
                    "label": "Social Media",
                    "value": "social"
                }
            ],
            "description": "How should we primarily reach out to you?"
        },
        {
            "id": "field_radio_1",
            "type": "radio",
            "label": "Experience Level",
            "required": true,
            "options": [
                {
                    "label": "Beginner",
                    "value": "beginner"
                },
                {
                    "label": "Intermediate",
                    "value": "intermediate"
                },
                {
                    "label": "Expert",
                    "value": "expert"
                }
            ],
            "description": "Select your self-assessed proficiency level."
        },
        {
            "id": "field_checkbox_1",
            "type": "checkbox",
            "label": "Interests",
            "required": false,
            "options": [
                {
                    "label": "Technology",
                    "value": "tech"
                },
                {
                    "label": "Design",
                    "value": "design"
                },
                {
                    "label": "Business",
                    "value": "business"
                },
                {
                    "label": "Health",
                    "value": "health"
                }
            ],
            "description": "Select all that apply."
        },
        {
            "id": "field_date_1",
            "type": "date",
            "label": "Date of Birth",
            "required": true,
            "description": "We use this to verify age-restricted content."
        }
    ],
    "logic_rules": [
        {
            "id": "rule_1",
            "name": "Show bio if name is provided",
            "condition_type": "any",
            "conditions": [
                {
                    "field_id": "field_text_1",
                    "operator": "is_not_empty",
                    "value": ""
                }
            ],
            "actions": [
                {
                    "field_id": "field_textarea_1",
                    "action": "show"
                }
            ]
        }
    ]
}